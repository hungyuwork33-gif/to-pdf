import sys
import os
from PIL import Image
from pdf2image import convert_from_path

def process_files(file_paths):
    # 桌面路徑
    desktop_path = os.path.join(os.path.expanduser("~"), "Desktop")
    
    # Poppler 路徑 (請確保此路徑正確)
    poppler_p = r"C:\Users\admin\Desktop\Python\文件轉換器\poppler-25.12.0\Library\bin"
    
    img_exts = ('.jpg', '.jpeg', '.png', '.jfif', '.bmp')

    for f_path in file_paths:
        name_only = os.path.splitext(os.path.basename(f_path))[0]
        ext = os.path.splitext(f_path)[1].lower()
        
        try:
            # 情況 A：丟進來的是 PDF (洗白：PDF -> 圖 -> PDF)
            if ext == '.pdf':
                images = convert_from_path(f_path, dpi=200, poppler_path=poppler_p)
                if images:
                    save_path = os.path.join(desktop_path, f"{name_only}_影像版.pdf")
                    images[0].save(save_path, "PDF", save_all=True, append_images=images[1:])
            
            # 情況 B：丟進來的是圖檔 (直接變 PDF)
            elif ext in img_exts:
                save_path = os.path.join(desktop_path, f"{name_only}.pdf")
                img = Image.open(f_path).convert("RGB")
                img.save(save_path, "PDF")
                
        except Exception:
            pass

if __name__ == "__main__":
    # 只要拖曳檔案到圖示上，Windows 就會把路徑傳給 sys.argv
    if len(sys.argv) > 1:
        process_files(sys.argv[1:])
